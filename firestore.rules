rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/Usuario/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/Usuario/$(request.auth.uid)).data.admin == true
          || get(/databases/$(database)/documents/Usuario/$(request.auth.uid)).data.tipo == 'admin'
        );
    }

    function activePrestador(uid) {
      return exists(/databases/$(database)/documents/Usuario/$(uid))
        && get(/databases/$(database)/documents/Usuario/$(uid)).data.tipo == 'prestador'
        && get(/databases/$(database)/documents/Usuario/$(uid)).data.contaAtiva == true
        && get(/databases/$(database)/documents/Usuario/$(uid)).data.assinaturaAtiva != false;
    }

    function touchesBillingFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny([
        'assinaturaAtiva',
        'contaAtiva',
        'dataCadastro',
        'dataVencimento',
        'ultimoPagamento',
        'statusPagamento',
        'valorMensalidade',
        'bloqueadoEm',
        'motivoBloqueio'
      ]);
    }

    function participantIn(data) {
      return signedIn()
        && data.participants is list
        && request.auth.uid in data.participants;
    }

    function areaParticipant(data) {
      return signedIn()
        && data.prestadoresIds is list
        && request.auth.uid in data.prestadoresIds;
    }

    match /Usuario/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.tipo in ['prestador', 'contratante']
        && (
          !request.resource.data.keys().hasAny(['admin'])
          || request.resource.data.admin == false
        )
        && (
          request.resource.data.tipo == 'contratante'
          || (
            request.resource.data.assinaturaAtiva == false
            && request.resource.data.contaAtiva == false
            && request.resource.data.statusPagamento == 'primeiro_pagamento_pendente'
          )
        );

      allow read: if isOwner(uid)
        || isAdmin()
        || (
          resource.data.tipo == 'prestador'
          && resource.data.contaAtiva == true
          && resource.data.assinaturaAtiva != false
        )
        || (signedIn() && resource.data.tipo == 'contratante');

      allow update: if isAdmin()
        || (
          isOwner(uid)
          && !touchesBillingFields()
          && !request.resource.data.diff(resource.data).changedKeys().hasAny(['admin', 'tipo'])
        );

      allow delete: if isOwner(uid) || isAdmin();

      match /Mensalidades/{periodKey} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update, delete: if false;
      }

      match /Notificacoes/{notifId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, delete: if isAdmin();
        allow update: if isAdmin()
          || (
            isOwner(uid)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lida'])
          );
      }

      match /Serv/{servId} {
        allow read: if signedIn() && (isOwner(uid) || activePrestador(uid) || isAdmin());
        allow create, update, delete: if isOwner(uid) || isAdmin();
      }

      match /Posts/{postId} {
        allow read: if signedIn() && (isOwner(uid) || activePrestador(uid) || isAdmin());
        allow create, update, delete: if isOwner(uid) || isAdmin();
      }
    }

    match /ServicosAdds/{uid}/ServicosOferecidos/{servicoId} {
      allow read: if signedIn() && (isOwner(uid) || activePrestador(uid) || isAdmin());
      allow create, update, delete: if isOwner(uid) || isAdmin();
    }

    match /ServicosAgendados/{prestadorId}/ServicoStatus/{servicoId} {
      allow read: if isAdmin()
        || isOwner(prestadorId)
        || (signedIn() && resource.data.clienteId == request.auth.uid);

      allow create: if isAdmin()
        || isOwner(prestadorId)
        || (signedIn() && request.resource.data.clienteId == request.auth.uid);

      allow update: if isAdmin()
        || isOwner(prestadorId)
        || (signedIn() && resource.data.clienteId == request.auth.uid)
        || (signedIn() && request.resource.data.clienteId == request.auth.uid);

      allow delete: if isAdmin()
        || isOwner(prestadorId)
        || (signedIn() && resource.data.clienteId == request.auth.uid);
    }

    match /ServicosClientes/{clienteId}/ServicoStatus/{servicoId} {
      allow read: if isAdmin()
        || isOwner(clienteId)
        || (signedIn() && resource.data.clienteId == request.auth.uid)
        || (signedIn() && resource.data.prestadorId == request.auth.uid);

      allow create: if isAdmin()
        || isOwner(clienteId)
        || (signedIn() && request.resource.data.prestadorId == request.auth.uid);

      allow update: if isAdmin()
        || isOwner(clienteId)
        || (signedIn() && resource.data.prestadorId == request.auth.uid)
        || (signedIn() && request.resource.data.prestadorId == request.auth.uid);

      allow delete: if isAdmin()
        || isOwner(clienteId)
        || (signedIn() && resource.data.prestadorId == request.auth.uid);
    }

    match /ServicosRejeitados/{prestadorId}/ServicoStatus/{servicoId} {
      allow read, create, update, delete: if isOwner(prestadorId) || isAdmin();
    }

    match /SolicitacoesArea/{requestId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.clienteId == request.auth.uid)
        || areaParticipant(resource.data);

      allow create: if signedIn() && request.resource.data.clienteId == request.auth.uid;

      allow update: if isAdmin()
        || (signedIn() && resource.data.clienteId == request.auth.uid)
        || areaParticipant(resource.data);

      allow delete: if isAdmin()
        || (signedIn() && resource.data.clienteId == request.auth.uid);
    }

    match /SolicitacoesMensalidade/{requestId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pendente';

      allow update, delete: if isAdmin();
    }

    function isContratante() {
      return signedIn()
        && exists(/databases/$(database)/documents/Usuario/$(request.auth.uid))
        && get(/databases/$(database)/documents/Usuario/$(request.auth.uid)).data.tipo == 'contratante';
    }

    match /ProblemasServicos/{problemaId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.clienteId == request.auth.uid)
        || (signedIn() && resource.data.prestadorId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.relatorId == request.auth.uid
        && (
          request.resource.data.clienteId == request.auth.uid
          || request.resource.data.prestadorId == request.auth.uid
        )
        && request.resource.data.status == 'pendente';

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.relatorId == request.auth.uid
          && request.resource.data.relatorId == resource.data.relatorId
          && request.resource.data.clienteId == resource.data.clienteId
          && request.resource.data.prestadorId == resource.data.prestadorId
          && request.resource.data.status == 'pendente'
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['descricao', 'criadoEm'])
        );
      allow delete: if isAdmin();
    }

    match /LocalizacoesPrestadores/{prestadorId} {
      allow read: if isOwner(prestadorId)
        || isAdmin()
        || (
          isContratante()
          && activePrestador(prestadorId)
          && resource.data.expiresAt > request.time
        );

      allow create, update: if isOwner(prestadorId)
        && activePrestador(prestadorId)
        && request.resource.data.prestadorId == prestadorId
        && request.resource.data.latitude is number
        && request.resource.data.latitude >= -90
        && request.resource.data.latitude <= 90
        && request.resource.data.longitude is number
        && request.resource.data.longitude >= -180
        && request.resource.data.longitude <= 180
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <= request.time + duration.value(3, 'h')
        && request.resource.data.keys().hasOnly([
          'prestadorId', 'latitude', 'longitude', 'accuracy', 'updatedAt', 'expiresAt'
        ]);

      allow delete: if isOwner(prestadorId) || isAdmin();
    }

    match /Chats/{chatId} {
      allow read, delete: if participantIn(resource.data) || isAdmin();
      allow create: if isAdmin()
        || (
          participantIn(request.resource.data)
          && request.resource.data.participants.size() == 2
          && request.resource.data.keys().hasOnly([
            'participants', 'lastMessage', 'lastMessageAt', 'updatedAt'
          ])
        );
      allow update: if isAdmin()
        || (
          participantIn(resource.data)
          && request.resource.data.participants == resource.data.participants
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'lastMessage', 'lastMessageAt', 'updatedAt'
          ])
        );

      match /Messages/{messageId} {
        allow read: if isAdmin()
          || participantIn(get(/databases/$(database)/documents/Chats/$(chatId)).data);

        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.keys().hasOnly(['text', 'senderId', 'createdAt'])
          && (
            isAdmin()
            || participantIn(getAfter(/databases/$(database)/documents/Chats/$(chatId)).data)
          );

        allow update, delete: if false;
      }
    }

    match /MercadoPagoWebhooks/{webhookId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
