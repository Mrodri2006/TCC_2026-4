{
  "expo": {
    "name": "Chamo",
    "slug": "chamo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-chamo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo-chamo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.m2006.firebase",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-chamo.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/logo-chamo.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permita o acesso à localização para preencher sua cidade e região automaticamente."
        }
      ],
      "./plugins/withMercadoPagoMavenRepo",
      [
        "./plugins/withMercadoPagoSdkDependencies",
        {
          "bomVersion": "+"
        }
      ],
      [
        "./plugins/withMercadoPagoSdkInit",
        {
          "publicKey": "APP_USR-b3cadce2-f241-4661-a74b-f7a123cd8cdf",
          "countryCode": "BR"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "802b6a82-2958-48f4-8adb-b819c26c0d07"
      }
    },
    "owner": "m2006"
  }
}
