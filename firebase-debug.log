[debug] [2026-06-09T03:49:42.218Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/info-650fe/rulesets {"name":"projects/info-650fe/rulesets/c1c0427a-9e75-4ea5-a6bc-141d7054c6b8","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(uid) {\n      return signedIn() && request.auth.uid == uid;\n    }\n\n    function isAdmin() {\n      return signedIn()\n        && exists(/databases/$(database)/documents/Usuario/$(request.auth.uid))\n        && (\n          get(/databases/$(database)/documents/Usuario/$(request.auth.uid)).data.admin == true\n          || get(/databases/$(database)/documents/Usuario/$(request.auth.uid)).data.tipo == 'admin'\n        );\n    }\n\n    function activePrestador(uid) {\n      return exists(/databases/$(database)/documents/Usuario/$(uid))\n        && get(/databases/$(database)/documents/Usuario/$(uid)).data.tipo == 'prestador'\n        && get(/databases/$(database)/documents/Usuario/$(uid)).data.contaAtiva == true\n        && get(/databases/$(database)/documents/Usuario/$(uid)).data.assinaturaAtiva != false;\n    }\n\n    function touchesBillingFields() {\n      return request.resource.data.diff(resource.data).changedKeys().hasAny([\n        'assinaturaAtiva',\n        'contaAtiva',\n        'dataCadastro',\n        'dataVencimento',\n        'ultimoPagamento',\n        'statusPagamento',\n        'valorMensalidade',\n        'bloqueadoEm',\n        'motivoBloqueio'\n      ]);\n    }\n\n    function participantIn(data) {\n      return signedIn()\n        && data.participants is list\n        && request.auth.uid in data.participants;\n    }\n\n    function areaParticipant(data) {\n      return signedIn()\n        && data.prestadoresIds is list\n        && request.auth.uid in data.prestadoresIds;\n    }\n\n    match /Usuario/{uid} {\n      allow create: if isOwner(uid)\n        && request.resource.data.tipo in ['prestador', 'contratante']\n        && (\n          !request.resource.data.keys().hasAny(['admin'])\n          || request.resource.data.admin == false\n        );\n\n      allow read: if isOwner(uid)\n        || isAdmin()\n        || (\n          resource.data.tipo == 'prestador'\n          && resource.data.contaAtiva == true\n          && resource.data.assinaturaAtiva != false\n        )\n        || (signedIn() && resource.data.tipo == 'contratante');\n\n      allow update: if isAdmin()\n        || (\n          isOwner(uid)\n          && !touchesBillingFields()\n          && !request.resource.data.diff(resource.data).changedKeys().hasAny(['admin', 'tipo'])\n        );\n\n      allow delete: if isOwner(uid) || isAdmin();\n\n      match /Mensalidades/{periodKey} {\n        allow read: if isOwner(uid) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /Notificacoes/{notifId} {\n        allow read: if isOwner(uid) || isAdmin();\n        allow create, delete: if false;\n        allow update: if isOwner(uid)\n          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lida']);\n      }\n\n      match /Serv/{servId} {\n        allow read: if signedIn() && (isOwner(uid) || activePrestador(uid) || isAdmin());\n        allow create, update, delete: if isOwner(uid) || isAdmin();\n      }\n\n      match /Posts/{postId} {\n        allow read: if signedIn() && (isOwner(uid) || activePrestador(uid) || isAdmin());\n        allow create, update, delete: if isOwner(uid) || isAdmin();\n      }\n    }\n\n    match /ServicosAdds/{uid}/ServicosOferecidos/{servicoId} {\n      allow read: if signedIn() && (isOwner(uid) || activePrestador(uid) || isAdmin());\n      allow create, update, delete: if isOwner(uid) || isAdmin();\n    }\n\n    match /ServicosAgendados/{prestadorId}/ServicoStatus/{servicoId} {\n      allow read: if isAdmin()\n        || isOwner(prestadorId)\n        || (signedIn() && resource.data.clienteId == request.auth.uid);\n\n      allow create: if isAdmin()\n        || isOwner(prestadorId)\n        || (signedIn() && request.resource.data.clienteId == request.auth.uid);\n\n      allow update: if isAdmin()\n        || isOwner(prestadorId)\n        || (signedIn() && resource.data.clienteId == request.auth.uid)\n        || (signedIn() && request.resource.data.clienteId == request.auth.uid);\n\n      allow delete: if isAdmin()\n        || isOwner(prestadorId)\n        || (signedIn() && resource.data.clienteId == request.auth.uid);\n    }\n\n    match /ServicosClientes/{clienteId}/ServicoStatus/{servicoId} {\n      allow read: if isAdmin()\n        || isOwner(clienteId)\n        || (signedIn() && resource.data.clienteId == request.auth.uid)\n        || (signedIn() && resource.data.prestadorId == request.auth.uid);\n\n      allow create: if isAdmin()\n        || isOwner(clienteId)\n        || (signedIn() && request.resource.data.prestadorId == request.auth.uid);\n\n      allow update: if isAdmin()\n        || isOwner(clienteId)\n        || (signedIn() && resource.data.prestadorId == request.auth.uid)\n        || (signedIn() && request.resource.data.prestadorId == request.auth.uid);\n\n      allow delete: if isAdmin()\n        || isOwner(clienteId)\n        || (signedIn() && resource.data.prestadorId == request.auth.uid);\n    }\n\n    match /ServicosRejeitados/{prestadorId}/ServicoStatus/{servicoId} {\n      allow read, create, update, delete: if isOwner(prestadorId) || isAdmin();\n    }\n\n    match /SolicitacoesArea/{requestId} {\n      allow read: if isAdmin()\n        || (signedIn() && resource.data.clienteId == request.auth.uid)\n        || areaParticipant(resource.data);\n\n      allow create: if signedIn() && request.resource.data.clienteId == request.auth.uid;\n\n      allow update: if isAdmin()\n        || (signedIn() && resource.data.clienteId == request.auth.uid)\n        || areaParticipant(resource.data);\n\n      allow delete: if isAdmin()\n        || (signedIn() && resource.data.clienteId == request.auth.uid);\n    }\n\n    match /Chats/{chatId} {\n      allow read, update, delete: if participantIn(resource.data) || isAdmin();\n      allow create: if participantIn(request.resource.data) || isAdmin();\n\n      match /Messages/{messageId} {\n        allow read: if isAdmin()\n          || participantIn(get(/databases/$(database)/documents/Chats/$(chatId)).data);\n\n        allow create: if signedIn()\n          && request.resource.data.senderId == request.auth.uid\n          && (\n            isAdmin()\n            || participantIn(getAfter(/databases/$(database)/documents/Chats/$(chatId)).data)\n          );\n\n        allow update, delete: if false;\n      }\n    }\n\n    match /MercadoPagoWebhooks/{webhookId} {\n      allow read, write: if false;\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-09T03:49:42.099391Z","metadata":{"services":["cloud.firestore"]}}
